# Map tiles (OpenFreeMap default — do NOT use OSM official tiles in production)
NEXT_PUBLIC_MAP_STYLE_URL=https://tiles.openfreemap.org/styles/liberty

# Realtime mode: postgres_changes | broadcast
NEXT_PUBLIC_REALTIME_MODE=postgres_changes

