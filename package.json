{
  "name": "openmatsuri",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:reset": "supabase db reset",
    "db:types": "supabase gen types typescript --local > packages/realtime/src/database.types.ts",
    "functions:dev": "supabase functions serve ingest-location ingest-soracom ingest-viewer-location --env-file .env.example"
  },
  "devDependencies": {
    "supabase": "^2.106.0",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
